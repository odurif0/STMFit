# ─────────────────────────────────────────────────────────────────────────────
# hpc/remote.env — STMFit remote-run configuration.
#
# Copy to `hpc/remote.env` and edit:   cp hpc/remote.env.example hpc/remote.env
# This file is gitignored (contains your MPCDF username/email).
# Sourced by hpc/launch_remote.sh.
#
# DESIGN: this file holds ONLY connection + resource settings. Remote PATHS
# (/u/<user>/..., /ptmp/<user>/...) are NOT set here — they are DERIVED from
# your username (read automatically from ~/.ssh/config via `ssh -G`) using the
# standard MPCDF convention. Override them only in the "Advanced" section below.
# ─────────────────────────────────────────────────────────────────────────────

# ── SSH / target system ─────────────────────────────────────────────────────
# Host alias from your ~/.ssh/config (must include ProxyJump through the MPCDF
# gateway + ControlMaster so you only type password+OTP once). See hpc/README.md.
#   Raven : raven   (Hostname raven.mpcdf.mpg.de)
#   Viper : viper   (Hostname viper.mpcdf.mpg.de)
STMFIT_SSH_HOST="${STMFIT_SSH_HOST:-raven}"

# ── Remote username ─────────────────────────────────────────────────────────
# Your MPCDF login name for FILE PATHS (/u/<user>/..., /ptmp/<user>/...). This
# is the short account name, NOT the SSH login you may type at the gateway
# (MPCDF often accepts your full email for SSH 2FA, but filesystem paths always
# use the short account name, e.g. "yourname"). Set this once; it's the only
# piece of personal info the launcher can't safely guess.
STMFIT_REMOTE_USER="${STMFIT_REMOTE_USER:-}"

# ── Run parameters (Slurm resources) ────────────────────────────────────────
# Number of array chunks (= number of parallel Slurm tasks). Each task handles
# 1/N of the files. Tune so each chunk finishes well under WALLTIME. Start 4–8.
N_CHUNKS="${N_CHUNKS:-4}"

# CPUs per task. batch_full.jl caps parallelism at min(4, nthreads, ntot), so 4
# is the sweet spot. Raising it won't help unless you also lift that cap.
CPUS_PER_TASK="${CPUS_PER_TASK:-4}"

# Walltime (HH:MM:SS) and memory per CPU (MB). The launcher multiplies
# MEM_PER_CPU by CPUS_PER_TASK to get the total `--mem` passed to Slurm — this
# is required by Raven's shared-job submit filter (which rejects --mem-per-cpu).
WALLTIME="${WALLTIME:-04:00:00}"
MEM_PER_CPU="${MEM_PER_CPU:-4000}"

# Julia module version on the cluster (run `find-module julia` on the login
# node to see options, e.g. 1.11.4). Empty = module default.
JULIA_MODULE_VERSION="${JULIA_MODULE_VERSION:-}"

# ── Per-run analysis knobs (NOT set here) ───────────────────────────────────
# batch_full.jl settings that change between RUNS — not between users — are NOT
# configured here. The launcher passes them to the cluster only when you set
# them on the command line. Defaults match batch_full.jl itself:
#
#   STMFIT_CONFIG        config/chitosan.toml   (TOML relative to repo root)
#   STMFIT_OUTDIR        results/best_plots     (output dir relative to repo root)
#   N_FILES              (unset = all files)
#   STMFIT_BATCH_ARGS    (extra flags, e.g. --selection-policy ... --skip-1d)
#
# Example — run the 10-20mer config on the first 200 files, skip 1D fits:
#   STMFIT_CONFIG=config/chitosan_10_20mer.toml N_FILES=200 \
#     STMFIT_BATCH_ARGS="--skip-1d" ./hpc/launch_remote.sh --watch
#
# Or make them persistent for your account by exporting in your shell
# (~/.zshrc / ~/.bashrc) instead of polluting this shared file.

# ── Notifications ───────────────────────────────────────────────────────────
# Your MPCDF/MPIM email for Slurm job mail. Empty = no mail.
STMFIT_MAIL_USER="${STMFIT_MAIL_USER:-}"

# ── Launcher behaviour ──────────────────────────────────────────────────────
# Polling interval (seconds) when --watch waits for the array to finish.
WATCH_POLL="${WATCH_POLL:-30}"

# rsync extra flags (e.g. --bwlimit=10000 to cap at 10 MB/s). Empty = none.
RSYNC_EXTRA="${RSYNC_EXTRA:-}"

# ─────────────────────────────────────────────────────────────────────────────
# ADVANCED — remote path overrides. Leave commented to use MPCDF conventions:
#   code :  /u/<user>/code/STMFit
#   data :  /ptmp/<user>/stmfit/data
# Uncomment & edit ONLY if your layout differs.
# ─────────────────────────────────────────────────────────────────────────────
# REMOTE_PROJECT_BASE="/u/<user>/code"      # repo dir = $REMOTE_PROJECT_BASE/STMFit
# REMOTE_DATA_BASE="/ptmp/<user>/stmfit"    # data dir = $REMOTE_DATA_BASE/data
#
# Local .sxm source dir to push FROM. Defaults to $STMFIT_DATA_DIR if set, else
# batch_full.jl's own default (see test/batch_full.jl, the STMFIT_DATA_DIR env).
# STMFIT_LOCAL_DATA=""
